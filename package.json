{
  "name": "knowledge-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "types": "wrangler types",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy:check": "wrangler deploy --dry-run --outdir dist",
    "verify": "bun run typecheck && bun run test && bun run deploy:check"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "fast-xml-parser": "^5.10.1",
    "hono": "^4.12.30",
    "linkedom": "^0.18.13",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.5",
    "@types/mozilla__readability": "^0.4.2",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.0",
    "wrangler": "^4.111.0"
  }
}
